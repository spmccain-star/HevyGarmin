# HevyGarmin configuration
PORT=3000
LOG_LEVEL=info

# How often to poll Garmin Connect for the latest heart rate reading (ms)
POLL_INTERVAL_MS=5000

# Garmin Connect account (unofficial API, username/password login)
GARMIN_EMAIL=your-garmin-email@example.com
GARMIN_PASSWORD=your-garmin-password

# Hevy API key (https://hevy.com -> Settings -> API)
HEVY_API_KEY=your-hevy-api-key
HEVY_API_BASE=https://api.hevyapp.com/v1
